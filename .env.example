# Required: Anthropic API key.
ANTHROPIC_API_KEY=sk-ant-...

# Optional model override (default: claude-sonnet-4-6).
LAB_MODEL=claude-sonnet-4-6

# Server port (default 3101).
PORT=3101

# In production: NODE_ENV=production
# NODE_ENV=production

# ── Auth ─────────────────────────────────────────────────────────────────────

# Lab session cookie signer. Required (auth is disabled if missing).
# Generate with: openssl rand -hex 32
LAB_SESSION_SECRET=

# Base URL the lab is served from (used for OAuth redirects).
LAB_PUBLIC_URL=http://localhost:3000

# ── GitHub App (NOT OAuth App) ───────────────────────────────────────────────

# Set these once you've registered a GitHub App. See server/github-app.ts for
# the exact form fields. Until set, the GitHub badge shows "setup needed" and
# the connect flow is disabled.

# Numeric App ID (top of the App's settings page on github.com)
LAB_GITHUB_APP_ID=

# Client ID from the App settings page (looks like: Iv23li...)
LAB_GITHUB_APP_CLIENT_ID=

# Generate by clicking "Generate a new client secret" on the App page.
LAB_GITHUB_APP_CLIENT_SECRET=

# The App's URL slug (the part after github.com/apps/ in its public URL).
LAB_GITHUB_APP_SLUG=

# Path to the .pem private key file (downloaded from "Generate a private key").
# Save the file under cloudwise-lab/secrets/ (gitignored).
LAB_GITHUB_APP_PRIVATE_KEY_PATH=./secrets/github-app.pem

# Encrypts user-to-server tokens at rest in our SQLite DB.
# Generate with: openssl rand -hex 32
LAB_TOKEN_ENC_KEY=
