{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "isolatedModules": true,
    "types": ["node"]
  },
  "include": ["server/**/*", "shared/**/*", "spike.ts", "smoke.ts", "auth-smoke.ts", "phase4-smoke.ts"],
  "exclude": ["node_modules", "scratch", "sessions", "web"]
}
